<?xml version="1.0" ?>
<!--
  Uni-Dingo Lite — Training-only fixed-base dual-arm robot

  Stripped from uni_dingo_dual_arm.urdf for memory-efficient RL training.
  Kept: base, chassis (box proxy), dual-arm mounting brackets, full Z1 arms + grippers.
  Removed: wheels, mounting brackets, IMU, pan-tilt, camera, decorative meshes.

  Chassis and arm-mount meshes replaced with simple collision primitives.
  Arm link collision geometry preserved for contact fidelity.
-->
<robot name="uni_dingo_lite">

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- Root: base_link (visual-only placeholder keeps minimal USD import clean) -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.001 0.001 0.001"/>
      </geometry>
      <material name="root_placeholder_black">
        <color rgba="0 0 0 1.0"/>
      </material>
    </visual>
  </link>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- Chassis: box proxy (replaces 25MB omni_chassis mesh)         -->
  <!-- Dimensions approximate Dingo-O footprint: ~0.57 x 0.42 x 0.24 -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <joint name="base_link_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="base_link"/>
    <child link="chassis_link"/>
  </joint>
  <link name="chassis_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.57 0.42 0.24"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.57 0.42 0.24"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="14"/>
      <inertia ixx="0.35498" ixy="0" ixz="0" iyy="0.7266" iyz="0" izz="1.0553"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- Left arm mount (cylinder proxy, replaces 4.8MB mesh)          -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <joint name="base_leftarm_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.15091 0.11708 0.57228"/>
    <parent link="base_link"/>
    <child link="leftarm_link"/>
  </joint>
  <link name="leftarm_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 -0.23614"/>
      <geometry>
        <cylinder length="0.47228" radius="0.02"/>
      </geometry>
      <material name="arm_support_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.23614"/>
      <geometry>
        <cylinder length="0.47228" radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 -0.23614"/>
      <mass value="1.4"/>
      <inertia ixx="0.02616231314666667" ixy="0" ixz="0"
               iyy="0.02616231314666667" iyz="0" izz="0.00028"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- Right arm mount (cylinder proxy, replaces 4.8MB mesh)         -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <joint name="base_rightarm_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.15091 -0.11708 0.57228"/>
    <parent link="base_link"/>
    <child link="rightarm_link"/>
  </joint>
  <link name="rightarm_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 -0.23614"/>
      <geometry>
        <cylinder length="0.47228" radius="0.02"/>
      </geometry>
      <material name="arm_support_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.23614"/>
      <geometry>
        <cylinder length="0.47228" radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 -0.23614"/>
      <mass value="1.4"/>
      <inertia ixx="0.02616231314666667" ixy="0" ixz="0"
               iyy="0.02616231314666667" iyz="0" izz="0.00028"/>
    </inertial>
  </link>

